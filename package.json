{
  "name": "mettig",
  "version": "0.1.0",
  "private": true,
  "description": "Mettig - local marketplace for services in Grozny and Chechnya",
  "workspaces": [
    "backend",
    "apps/client",
    "apps/business",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.17.0"
  }
}
