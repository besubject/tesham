{
  "name": "@mettig/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Mettig backend API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "jest",
    "test:e2e": "jest src/__tests__/e2e-flow.test.ts",
    "test:db:up": "docker compose -f ../docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f ../docker-compose.test.yml down -v",
    "test:db:migrate": "DATABASE_URL=postgresql://mettig_test:mettig_test@localhost:5434/mettig_test ts-node src/db/migrate.ts",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:rollback": "ts-node src/db/rollback.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "db:check": "ts-node src/db/check.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.611.0",
    "@aws-sdk/s3-request-presigner": "^3.611.0",
    "@types/sanitize-html": "^2.16.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.15",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
