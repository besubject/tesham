# ============================================
# Mettig — Environment Variables (example)
# ============================================

# ---------- App ----------
NODE_ENV=development
PORT=3000
API_URL=https://api.mettig.ru
WEB_URL=https://mettig.ru
DEFAULT_LANGUAGE=ru

# ---------- PostgreSQL ----------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mettig
DATABASE_USER=mettig
DATABASE_PASSWORD=
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ---------- JWT ----------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ---------- SMS.ru ----------
SMSRU_API_ID=
SMSRU_SENDER=Mettig
SMS_RATE_LIMIT_MAX=3
SMS_RATE_LIMIT_WINDOW_MIN=10

# ---------- WhatsApp Business API (Green API) ----------
GREENAPI_INSTANCE_ID=
GREENAPI_API_TOKEN=

# ---------- S3 (Yandex Object Storage) ----------
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=mettig
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---------- Expo Push Notifications ----------
EXPO_ACCESS_TOKEN=

# ---------- VPS / Deploy ----------
VPS_HOST=
VPS_USER=root

# ---------- Event Tracking ----------
EVENT_HASH_SALT=
